{
  "name": "shorturl",
  "version": "0.1.0",
  "description": "ShortURL service — Starter Kit for Claude AI Agent Team training",
  "main": "src/api/server.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn src/api/server.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "express": "^4.19.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
