# ShortURL 服務環境變數範本
# 複製為 .env 後填入實際值（.env 已被 .gitignore 排除，且被 Hook 保護）

# Server
PORT=3000
NODE_ENV=development

# Database
# 開發用 SQLite
DATABASE_URL=sqlite:./dev.db
# 生產用 PostgreSQL
# DATABASE_URL=postgres://user:password@localhost:5432/shorturl

# Short URL
SHORT_URL_BASE=http://localhost:3000
SHORT_CODE_LENGTH=7

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
